{
  "name": "personal-blog",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:init": "node scripts/init-db.js",
    "d1:migrate:local": "wrangler d1 execute personal-blog-db --local --file=migrations/0001_init.sql",
    "d1:migrate:remote": "wrangler d1 execute personal-blog-db --remote --file=migrations/0001_init.sql",
    "test": "echo \"No tests configured\"",
    "build:frontend": "npm run build --prefix frontend",
    "deploy": "npm run build:frontend && wrangler deploy",
    "pages:deploy": "npm run deploy",
    "pages:dev": "npm run build:frontend && wrangler dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "wrangler": "^4.44.0"
  }
}
